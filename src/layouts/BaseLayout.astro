---
import siteStyles from '../styles/site.css?url';

const assetVersion = '20260315';
const baseStyleHref = '/assets/site.css';
const baseScriptSrc = '/assets/site.mjs';
const baseAvatar = '/avatar.jpg';

const siteUrl = 'https://www.chijunsima.com';
const siteName = 'Chijun Sima';
const siteTitle = 'Chijun Sima — ML Systems Researcher';
const siteDescription = 'Chijun Sima — ML systems researcher at Tencent (WeChat). Research on efficient AI systems, model freshness, recommender systems, and LLM serving. Co-first author, OSDI 2022 (Ekko). LLVM developer with commit access.';
---
<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <link rel="preload" href={baseAvatar} data-asset-href={baseAvatar} as="image" type="image/jpeg" fetchpriority="high" data-vite-ignore />
    <link rel="preload" href={siteStyles} data-asset-href={baseStyleHref} as="style" data-vite-ignore />
    <link rel="modulepreload" href={baseScriptSrc} data-asset-href={baseScriptSrc} data-vite-ignore />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="author" content={siteName} />
    <meta name="asset-version" content={assetVersion} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101820" media="(prefers-color-scheme: dark)" />
    <meta name="keywords" content="Chijun Sima, MLSys, Machine Learning Systems, Efficient AI, Model Freshness, Recommender Systems, LLM Serving, OSDI, Ekko, LLVM, Tencent, WeChat, Systems Research" />

    <link rel="canonical" href={`${siteUrl}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={`${siteUrl}/`} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={`${siteUrl}/avatar.jpg`} />
    <meta property="og:image:width" content="400" />
    <meta property="og:image:height" content="400" />
    <meta property="og:image:alt" content="Portrait of Chijun Sima" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="profile:first_name" content="Chijun" />
    <meta property="profile:last_name" content="Sima" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={`${siteUrl}/avatar.jpg`} />
    <meta name="twitter:image:alt" content="Portrait of Chijun Sima" />

    <!-- Favicons & PWA -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- LLM/AI agent discovery -->
    <link rel="alternate" type="text/plain" title="LLM context (concise)" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLM context (full)" href="/llms-full.txt" />

    <!-- Dark-mode flash prevention -->
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('theme');
          var d = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (s === 'dark' || (!s && d)) document.documentElement.classList.add('dark');
        } catch (_) { /* storage unavailable */ }
      })();
    </script>

    <!-- JSON-LD: Person (rich structured data for search engines and LLM agents) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Chijun Sima",
      "givenName": "Chijun",
      "familyName": "Sima",
      "url": siteUrl,
      "image": {
        "@type": "ImageObject",
        "url": `${siteUrl}/avatar.jpg`,
        "width": 400,
        "height": 400
      },
      "jobTitle": "Senior Software Development Engineer",
      "description": "ML systems researcher focused on efficient AI: scalable training/serving, system–algorithm co-design, model freshness, recommender systems, LLM serving. Co-first author of Ekko (OSDI 2022). LLVM developer with commit access.",
      "worksFor": {
        "@type": "Organization",
        "name": "Tencent",
        "department": "WeChat",
        "url": "https://www.tencent.com"
      },
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "South China University of Technology",
        "url": "https://www.scut.edu.cn"
      },
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "degree",
        "name": "B.Eng. in Computer Science and Technology (Innovation Class)",
        "recognizedBy": {
          "@type": "CollegeOrUniversity",
          "name": "South China University of Technology"
        }
      },
      "award": [
        "Tencent Technology Breakthrough Award (Gold Prize), 2022 — Project Lead, Ekko",
        "Bronze Medal, ACM-ICPC Asia Xi'an Regional Contest (2017)",
        "Second Prize, 15th China Collegiate Programming Contest (Guangdong Division)"
      ],
      "knowsAbout": [
        "Machine Learning Systems",
        "MLSys",
        "Efficient AI",
        "Model Freshness",
        "Recommender Systems",
        "Deep Learning",
        "Deep Learning Recommendation Models",
        "LLM Serving",
        "KV-Cache Management",
        "WebAssembly",
        "LLVM",
        "Compilers",
        "Distributed Systems"
      ],
      "email": "mailto:simachijun@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Guangzhou",
        "addressCountry": "CN"
      },
      "sameAs": [
        "https://www.linkedin.com/in/chijun-sima/",
        "https://github.com/NutshellySima",
        "https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en"
      ],
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `${siteUrl}/`
      }
    })} />

    <!-- JSON-LD: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": `${siteUrl}/`,
      "name": `${siteName} — ML Systems Researcher`,
      "description": siteDescription,
      "author": { "@type": "Person", "@id": `${siteUrl}/#person` },
      "inLanguage": "en"
    })} />

    <!-- JSON-LD: ScholarlyArticle for flagship paper -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ScholarlyArticle",
      "name": "Ekko: A Large-Scale Deep Learning Recommender System with Low-Latency Model Update",
      "url": "https://www.usenix.org/conference/osdi22/presentation/sima",
      "datePublished": "2022",
      "isPartOf": {
        "@type": "PublicationEvent",
        "name": "OSDI 2022",
        "organizer": { "@type": "Organization", "name": "USENIX" }
      },
      "author": [
        { "@type": "Person", "name": "Chijun Sima", "@id": `${siteUrl}/#person` },
        { "@type": "Person", "name": "Yao Fu" },
        { "@type": "Person", "name": "Man-Kit Sit" },
        { "@type": "Person", "name": "Liyi Guo" },
        { "@type": "Person", "name": "Xuri Gong" },
        { "@type": "Person", "name": "Feng Lin" },
        { "@type": "Person", "name": "Junyu Wu" },
        { "@type": "Person", "name": "Yongsheng Li" },
        { "@type": "Person", "name": "Haidong Rong" },
        { "@type": "Person", "name": "Pierre-Louis Aublin" },
        { "@type": "Person", "name": "Luo Mai" }
      ]
    })} />

    <!-- JSON-LD: ScholarlyArticle for second paper -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ScholarlyArticle",
      "name": "Dynamic Barycenter Averaging Kernel in RBF Networks for Time Series Classification",
      "datePublished": "2019",
      "isPartOf": {
        "@type": "PublicationVolume",
        "name": "IEEE Access"
      },
      "author": [
        { "@type": "Person", "name": "Kejian Shi" },
        { "@type": "Person", "name": "Hongyang Qin" },
        { "@type": "Person", "name": "Chijun Sima", "@id": `${siteUrl}/#person` },
        { "@type": "Person", "name": "Sen Li" },
        { "@type": "Person", "name": "Lifeng Shen" },
        { "@type": "Person", "name": "Qianli Ma" }
      ]
    })} />

    <!-- Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "74efc9100b074000b7c818e83d174ea4"}'></script>
    <script is:inline>
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,'clarity','script','cr8ptqxm1m');
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RDCCF82CG7"></script>
    <script is:inline>
      window.dataLayer=window.dataLayer||[];function gtag(){window.dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-RDCCF82CG7');
    </script>

    <link rel="stylesheet" href={siteStyles} data-asset-href={baseStyleHref} data-vite-ignore />

    <script is:inline>
      (function () {
        var loc = ['localhost','127.0.0.1'];
        if (loc.includes(window.location.hostname)) return;
        var meta = document.querySelector('meta[name="asset-version"]');
        var v = meta ? meta.content : '';
        var wv = function(u){return v?(u.includes('?')?u+'&v='+v:u+'?v='+v):u};
        window.__withAssetVersion__ = wv;
        document.querySelectorAll('[data-asset-href]').forEach(function(el){
          var b=el.getAttribute('data-asset-href');if(b)el.setAttribute('href',wv(b));
        });
      })();
    </script>
  </head>
  <body class="font-sans antialiased">
    <slot />

    <script type="module" src={baseScriptSrc} data-asset-src={baseScriptSrc} defer></script>
    <script is:inline>
      (function () {
        var loc = ['localhost','127.0.0.1'];
        if (loc.includes(window.location.hostname)) return;
        var wv = window.__withAssetVersion__;
        if (!wv) return;
        document.querySelectorAll('[data-asset-src]').forEach(function(el){
          var b=el.getAttribute('data-asset-src');
          var c=el.getAttribute('src')||'';
          if(!b)return;if(c&&c.includes('v='))return;
          el.setAttribute('src',wv(b));
        });
      })();
    </script>
  </body>
</html>
