---
import BaseLayout from '../layouts/BaseLayout.astro';

const news = [
  { date: '2025', text: 'Reviewing for CVPR 2025, ICLR 2025 Workshop (FM-Wild), NeurIPS 2025 Workshop (Efficient Reasoning)' },
  { date: '2022', text: 'Ekko published at OSDI 2022; invited talks at Tencent WeChat AI, DataFun, TechBeat' },
  { date: '2022', text: 'Tencent Technology Breakthrough Award (Gold Prize) — Project Lead, Ekko' },
];

const publications = [
  {
    venue: 'OSDI 2022',
    title: 'Ekko: A Large-Scale Deep Learning Recommender System with Low-Latency Model Update',
    authors: 'Chijun Sima*, Yao Fu*, Man-Kit Sit, Liyi Guo, Xuri Gong, Feng Lin, Junyu Wu, Yongsheng Li, Haidong Rong, Pierre-Louis Aublin, Luo Mai',
    link: 'https://www.usenix.org/conference/osdi22/presentation/sima',
    note: '(* = co-first author)',
    year: '2022',
  },
  {
    venue: 'IEEE Access 2019',
    title: 'Dynamic Barycenter Averaging Kernel in RBF Networks for Time Series Classification',
    authors: 'Kejian Shi, Hongyang Qin, Chijun Sima, Sen Li, Lifeng Shen, Qianli Ma',
    link: '',
    note: '',
    year: '2019',
  },
];

const experience = [
  {
    period: 'Jul 2020 – Present',
    startDate: '2020-07',
    role: 'Senior Software Development Engineer',
    org: 'Tencent (WeChat)',
    orgUrl: 'https://www.tencent.com',
    bullets: [
      'Led Ekko: low-latency model update system for large-scale recommendation (published at OSDI 2022, co-first author).',
      'Designed data and feature platform with WebAssembly-based in-process isolation and locality-aware operator placement (data movement reduced up to 1,200x).',
      'Developing LLM serving mechanisms with remote KV-cache storage and compression.',
    ],
  },
  {
    period: '2018 – Present',
    startDate: '2018',
    role: 'Developer (commit access)',
    org: 'LLVM',
    orgUrl: 'https://llvm.org',
    bullets: [
      'Improved Semi-NCA performance and optimization pipeline (LLVM 9.0).',
      'Unified dominator-tree update APIs (LLVM 7.0).',
      'Reported speedups up to 1,980x on real-world inputs.',
    ],
  },
];

const education = {
  period: 'Sep 2016 – Jun 2020',
  startDate: '2016-09',
  endDate: '2020-06',
  degree: 'B.Eng. in Computer Science',
  school: 'South China University of Technology',
  schoolUrl: 'https://www.scut.edu.cn',
  detail: 'Innovation Class · GPA 3.85 / 4.00 · Rank 1 / 28',
};

const ekkoHighlights = [
  'WAN bandwidth reduced by 92 %',
  'Machine cost reduced by 49 %',
  '2.4 s model-update latency',
  '10,000 × model-size scaling (GB → tens of TB)',
  'Deployed in WeChat recommendation; serves 1 B+ users daily',
];

const talks = [
  { text: 'Tencent WeChat AI Department, Shenzhen', date: 'Jun 2022' },
  { text: 'DataFun, Virtual', date: 'Aug 2022' },
  { text: 'TechBeat, Virtual', date: 'Sep 2022' },
];

const awards = [
  { text: 'Tencent Technology Breakthrough Award (Gold Prize) — Project Lead, Ekko', year: '2022' },
  { text: "ACM-ICPC Asia Xi'an Regional — Bronze", year: '2017' },
  { text: 'CCPC Guangdong Division — Second Prize (out of 177 teams)', year: '' },
];

const reviewing = [
  'CVPR 2025',
  'ICLR 2025 Workshop on FM-Wild',
  'NeurIPS 2025 Workshop on Efficient Reasoning',
];

const references = [
  { label: 'OSDI 2022 paper', href: 'https://www.usenix.org/conference/osdi22/presentation/sima' },
  { label: 'WeChat official write-up', href: 'https://mp.weixin.qq.com/s/gBD3mdoRRlGI8bmXp2OBMA' },
  { label: 'Tencent official write-up', href: 'https://mp.weixin.qq.com/s/hS5ZebOC7oQz_Itud0A_Rg' },
  { label: 'Synced Review coverage', href: 'https://mp.weixin.qq.com/s/Vriupgqusj1zJmSuYU9WjA' },
  { label: 'Google Scholar', href: 'https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en' },
];
---
<BaseLayout>
  <a href="#main" class="skip-link">Skip to main content</a>

  <div class="page-wrapper">
    <main id="main" tabindex="-1" itemscope itemtype="https://schema.org/Person">
      <meta itemprop="name" content="Chijun Sima" />
      <meta itemprop="url" content="https://www.chijunsima.com" />

      <!-- ── Header ── -->
      <header class="site-header">
        <div class="header-top">
          <nav class="header-nav no-print" aria-label="Page sections">
            <a href="#publications">Publications</a>
            <a href="#experience">Experience</a>
            <a href="#service">Service</a>
            <a href="/cv.pdf">CV</a>
          </nav>
          <button id="theme-toggle" class="theme-toggle no-print" aria-label="Toggle dark mode" aria-pressed="false">☾</button>
        </div>

        <div class="header-card">
          <img
            src="/avatar.jpg"
            data-asset-src="/avatar.jpg"
            alt="Portrait of Chijun Sima"
            width="144"
            height="144"
            itemprop="image"
            class="avatar"
            loading="eager"
            decoding="async"
          />
          <div class="header-info">
            <h1 class="header-name">Chijun Sima</h1>
            <p class="header-title">
              Senior Software Development Engineer,
              <a href="https://www.tencent.com" itemprop="worksFor" itemscope itemtype="https://schema.org/Organization" target="_blank" rel="noopener noreferrer">
                <span itemprop="name">Tencent (WeChat)</span>
              </a>
            </p>
            <p class="header-location">
              <span aria-hidden="true">&#x25CB;</span>
              Guangzhou, China
            </p>

            <div class="header-links" role="list" aria-label="Contact and profiles">
              <a role="listitem" href="mailto:simachijun@gmail.com" itemprop="email">Email</a>
              <a role="listitem" href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" itemprop="sameAs" target="_blank" rel="noopener noreferrer">Google Scholar</a>
              <a role="listitem" href="https://github.com/NutshellySima" itemprop="sameAs" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a role="listitem" href="https://www.linkedin.com/in/chijun-sima/" itemprop="sameAs" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a role="listitem" href="/cv.pdf">CV <span class="muted-inline">(PDF)</span></a>
            </div>
          </div>
        </div>
      </header>

      <!-- ── Research Interests ── -->
      <section id="research" class="content-section" aria-labelledby="h-research">
        <h2 id="h-research" class="section-heading">Research Interests</h2>
        <p class="body-text">
          I work on <strong>efficient AI systems</strong>&hairsp;: scalable and cost-effective training and serving through system–algorithm co-design.
          My current focus is on recommender and LLM systems under strict latency and cost constraints, including <em>model freshness</em>, <em>distributed model updates</em>, and <em>KV-cache management</em>.
        </p>
      </section>

      <!-- ── News ── -->
      <section id="news" class="content-section" aria-labelledby="h-news">
        <h2 id="h-news" class="section-heading">News</h2>
        <ul class="news-list" role="list">
          {news.map((item) => (
            <li class="news-item">
              <time class="news-date" datetime={item.date}>{item.date}</time>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── Selected Publications ── -->
      <section id="publications" class="content-section" aria-labelledby="h-pub">
        <h2 id="h-pub" class="section-heading">Selected Publications</h2>
        <p class="section-note">
          Full list on <a href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" class="text-link" target="_blank" rel="noopener noreferrer">Google Scholar</a>.
        </p>
        <ol class="pub-list" reversed>
          {publications.map((pub) => (
            <li>
              <article class="pub-item" itemscope itemtype="https://schema.org/ScholarlyArticle">
                <div class="pub-heading">
                  <span class="pub-venue">{pub.venue}</span>
                  {pub.link ? (
                    <a href={pub.link} class="pub-title text-link" itemprop="url" target="_blank" rel="noopener noreferrer">
                      <span itemprop="name">{pub.title}</span>
                    </a>
                  ) : (
                    <span class="pub-title" itemprop="name">{pub.title}</span>
                  )}
                </div>
                <p class="pub-authors" set:html={pub.authors.replace(/Chijun Sima/g, '<strong class="pub-self" itemprop="author">Chijun Sima</strong>')} />
                {pub.note && <p class="pub-note">{pub.note}</p>}
              </article>
            </li>
          ))}
        </ol>
      </section>

      <!-- ── Ekko Highlights ── -->
      <section id="ekko" class="content-section" aria-labelledby="h-ekko">
        <h2 id="h-ekko" class="section-heading">Ekko&hairsp;: Key Results</h2>
        <p class="section-desc">
          Low-latency model update system for large-scale deep learning recommendation.
          Addresses model staleness through compressed update dissemination, optimization-based placement, and safe rollback.
        </p>
        <ul class="highlight-list" aria-label="Key metrics">
          {ekkoHighlights.map((h) => (
            <li>{h}</li>
          ))}
        </ul>
        <p class="ref-links">
          {references.map((ref, i) => (
            <Fragment>
              {i > 0 && <span class="ref-sep" aria-hidden="true">·</span>}
              <a href={ref.href} class="text-link" target="_blank" rel="noopener noreferrer">{ref.label}</a>
            </Fragment>
          ))}
        </p>
      </section>

      <!-- ── Experience ── -->
      <section id="experience" class="content-section" aria-labelledby="h-exp">
        <h2 id="h-exp" class="section-heading">Experience</h2>
        <div class="timeline">
          {experience.map((entry) => (
            <article class="timeline-entry" itemscope itemtype="https://schema.org/OrganizationRole">
              <div class="timeline-head">
                <time class="timeline-period" datetime={entry.startDate}>{entry.period}</time>
                <p class="timeline-role">
                  <strong itemprop="roleName">{entry.role}</strong>,{' '}
                  <a href={entry.orgUrl} target="_blank" rel="noopener noreferrer" itemprop="memberOf" itemscope itemtype="https://schema.org/Organization">
                    <span itemprop="name">{entry.org}</span>
                  </a>
                </p>
              </div>
              <ul class="timeline-bullets">
                {entry.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <!-- ── Education ── -->
      <section id="education" class="content-section" aria-labelledby="h-edu">
        <h2 id="h-edu" class="section-heading">Education</h2>
        <article class="timeline-entry" itemprop="alumniOf" itemscope itemtype="https://schema.org/EducationalOrganization">
          <div class="timeline-head">
            <time class="timeline-period" datetime={education.startDate}>{education.period}</time>
            <p class="timeline-role">
              <strong>{education.degree}</strong>,{' '}
              <a href={education.schoolUrl} target="_blank" rel="noopener noreferrer">
                <span itemprop="name">{education.school}</span>
              </a>
            </p>
          </div>
          <p class="timeline-detail">{education.detail}</p>
        </article>
      </section>

      <!-- ── Talks ── -->
      <section id="talks" class="content-section" aria-labelledby="h-talks">
        <h2 id="h-talks" class="section-heading">Invited Talks</h2>
        <ul class="compact-list">
          {talks.map((t) => (
            <li>
              {t.text}
              <span class="muted-inline">({t.date})</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── Service & Awards ── -->
      <section id="service" class="content-section" aria-labelledby="h-service">
        <h2 id="h-service" class="section-heading">Service &amp; Awards</h2>
        <div class="two-col">
          <div>
            <h3 class="subsection-heading">Reviewing</h3>
            <ul class="compact-list">
              {reviewing.map((s) => <li>{s}</li>)}
            </ul>
          </div>
          <div>
            <h3 class="subsection-heading">Awards</h3>
            <ul class="compact-list">
              {awards.map((a) => (
                <li>
                  {a.text}
                  {a.year && <span class="muted-inline">({a.year})</span>}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer ── -->
    <footer class="site-footer no-print" role="contentinfo">
      <p>&copy; <span id="year"></span> Chijun Sima</p>
    </footer>
  </div>
</BaseLayout>
