---
import BaseLayout from '../layouts/BaseLayout.astro';

const news = [
  { date: '2025', text: 'Reviewing for CVPR 2025, ICLR 2025 Workshop (FM-Wild), NeurIPS 2025 Workshop (Efficient Reasoning)' },
  { date: '2022', text: 'Ekko published at OSDI 2022; invited talks at Tencent WeChat AI, DataFun, TechBeat' },
  { date: '2022', text: 'Tencent Technology Breakthrough Award (Gold Prize) — Project Lead, Ekko' },
];

const publications = [
  {
    venue: 'OSDI 2022',
    title: 'Ekko: A Large-Scale Deep Learning Recommender System with Low-Latency Model Update',
    authors: 'Chijun Sima*, Yao Fu*, Man-Kit Sit, Liyi Guo, Xuri Gong, Feng Lin, Junyu Wu, Yongsheng Li, Haidong Rong, Pierre-Louis Aublin, Luo Mai',
    link: 'https://www.usenix.org/conference/osdi22/presentation/sima',
    note: '(* = co-first author)',
  },
  {
    venue: 'IEEE Access 2019',
    title: 'Dynamic Barycenter Averaging Kernel in RBF Networks for Time Series Classification',
    authors: 'Kejian Shi, Hongyang Qin, Chijun Sima, Sen Li, Lifeng Shen, Qianli Ma',
    link: '',
    note: '',
  },
];

const experience = [
  {
    period: 'Jul 2020 – Present',
    role: 'Senior Software Development Engineer',
    org: 'Tencent (WeChat)',
    bullets: [
      'Led Ekko: low-latency model update system for large-scale recommendation (published at OSDI 2022, co-first author).',
      'Designed data and feature platform with WebAssembly-based in-process isolation and locality-aware operator placement (data movement reduced up to 1,200x).',
      'Developing LLM serving mechanisms with remote KV-cache storage and compression.',
    ],
  },
  {
    period: '2018 – Present',
    role: 'Developer (commit access)',
    org: 'LLVM',
    bullets: [
      'Improved Semi-NCA performance and optimization pipeline (LLVM 9.0).',
      'Unified dominator-tree update APIs (LLVM 7.0).',
      'Reported speedups up to 1,980x on real-world inputs.',
    ],
  },
];

const education = {
  period: 'Sep 2016 – Jun 2020',
  degree: 'B.Eng. in Computer Science',
  school: 'South China University of Technology',
  detail: 'Innovation Class · GPA 3.85/4.00 · Rank 1/28',
};

const ekkoHighlights = [
  'WAN bandwidth reduced by 92%',
  'Machine cost reduced by 49%',
  '2.4s model-update latency',
  '10,000x model-size scaling (GB → tens of TB)',
  'Deployed in WeChat recommendation; serves 1B+ users daily',
];

const talks = [
  'Tencent WeChat AI Department, Shenzhen (Jun 2022)',
  'DataFun, Virtual (Aug 2022)',
  'TechBeat, Virtual (Sep 2022)',
];

const awards = [
  'Tencent Technology Breakthrough Award (Gold Prize), 2022 — Project Lead, Ekko',
  "ACM-ICPC Asia Xi'an Regional — Bronze (2017)",
  'CCPC Guangdong Division — Second Prize (out of 177 teams)',
];

const service = [
  'CVPR 2025',
  'ICLR 2025 Workshop on FM-Wild',
  'NeurIPS 2025 Workshop on Efficient Reasoning',
];

const references = [
  { label: 'OSDI 2022 paper', href: 'https://www.usenix.org/conference/osdi22/presentation/sima' },
  { label: 'WeChat official write-up', href: 'https://mp.weixin.qq.com/s/gBD3mdoRRlGI8bmXp2OBMA' },
  { label: 'Tencent official write-up', href: 'https://mp.weixin.qq.com/s/hS5ZebOC7oQz_Itud0A_Rg' },
  { label: 'Synced Review coverage', href: 'https://mp.weixin.qq.com/s/Vriupgqusj1zJmSuYU9WjA' },
  { label: 'Google Scholar', href: 'https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en' },
];
---
<BaseLayout>
  <a href="#main" class="skip-link">Skip to main content</a>

  <main id="main" tabindex="-1">
    <!-- ===== Header ===== -->
    <header class="academic-container pt-10 pb-8 sm:pt-14 sm:pb-10">
      <div class="flex justify-end mb-4 no-print">
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode" aria-pressed="false">☾</button>
      </div>

      <div class="flex flex-col sm:flex-row gap-6 items-start">
        <img
          src="/avatar.jpg"
          data-asset-src="/avatar.jpg"
          alt="Chijun Sima"
          width="144"
          height="144"
          class="w-32 h-32 sm:w-36 sm:h-36 rounded-lg object-cover flex-shrink-0"
          loading="eager"
          decoding="async"
        />
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-50">Chijun Sima</h1>
          <p class="text-lg text-gray-600 dark:text-gray-400 mt-1">
            Senior Software Development Engineer, <a href="https://www.tencent.com" class="paper-link" target="_blank" rel="noopener noreferrer">Tencent (WeChat)</a>
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Guangzhou, China</p>

          <div class="header-links flex flex-wrap gap-x-4 gap-y-1 mt-3 text-sm">
            <a href="mailto:simachijun@gmail.com">Email</a>
            <a href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Google Scholar</a>
            <a href="https://github.com/NutshellySima" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://www.linkedin.com/in/chijun-sima/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="/cv.pdf">CV (PDF)</a>
          </div>
        </div>
      </div>
    </header>

    <!-- ===== Research Interests ===== -->
    <section id="research" class="academic-container pb-8">
      <h2 class="section-heading">Research Interests</h2>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
        I work on <strong>efficient AI systems</strong>: scalable and cost-effective training and serving through system–algorithm co-design.
        My current focus is on recommender and LLM systems under strict latency and cost constraints, including model freshness, distributed model updates, and KV-cache management.
      </p>
    </section>

    <!-- ===== News ===== -->
    <section id="news" class="academic-container pb-8">
      <h2 class="section-heading">News</h2>
      <ul class="space-y-2">
        {news.map((item) => (
          <li class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
            <span class="news-date">{item.date}</span>
            <span>{item.text}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ===== Selected Publications ===== -->
    <section id="publications" class="academic-container pb-8">
      <h2 class="section-heading">Selected Publications</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
        Full list on <a href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" class="paper-link" target="_blank" rel="noopener noreferrer">Google Scholar</a>.
      </p>
      <div>
        {publications.map((pub) => (
          <div class="pub-item">
            <div class="flex flex-wrap items-baseline gap-x-2">
              <span class="pub-venue">{pub.venue}</span>
              {pub.link ? (
                <a href={pub.link} class="pub-title paper-link" target="_blank" rel="noopener noreferrer">{pub.title}</a>
              ) : (
                <span class="pub-title">{pub.title}</span>
              )}
            </div>
            <p class="pub-authors mt-1" set:html={pub.authors.replace(/Chijun Sima/g, '<span class="pub-self">Chijun Sima</span>')} />
            {pub.note && <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{pub.note}</p>}
          </div>
        ))}
      </div>
    </section>

    <!-- ===== Ekko Highlights ===== -->
    <section id="ekko" class="academic-container pb-8">
      <h2 class="section-heading">Ekko: Key Results</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
        Ekko is a low-latency model update system for large-scale deep learning recommendation.
        It addresses model staleness with compressed update dissemination, optimization-based placement, and safe rollback.
      </p>
      <ul class="list-disc list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300">
        {ekkoHighlights.map((h) => (
          <li>{h}</li>
        ))}
      </ul>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-3">
        See also:
        {references.map((ref, i) => (
          <Fragment>
            {i > 0 && ' · '}
            <a href={ref.href} class="paper-link" target="_blank" rel="noopener noreferrer">{ref.label}</a>
          </Fragment>
        ))}
      </p>
    </section>

    <!-- ===== Experience ===== -->
    <section id="experience" class="academic-container pb-8">
      <h2 class="section-heading">Experience</h2>
      <div>
        {experience.map((entry) => (
          <div class="timeline-entry">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
              <span class="timeline-period whitespace-nowrap">{entry.period}</span>
              <p class="font-semibold text-gray-900 dark:text-gray-100">{entry.role}, {entry.org}</p>
            </div>
            <ul class="list-disc list-inside mt-1.5 space-y-1 text-sm text-gray-700 dark:text-gray-300 ml-0 sm:ml-[calc(5.5rem+0.75rem)]">
              {entry.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== Education ===== -->
    <section id="education" class="academic-container pb-8">
      <h2 class="section-heading">Education</h2>
      <div class="timeline-entry">
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
          <span class="timeline-period whitespace-nowrap">{education.period}</span>
          <p class="font-semibold text-gray-900 dark:text-gray-100">{education.degree}, {education.school}</p>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 sm:ml-[calc(5.5rem+0.75rem)]">{education.detail}</p>
      </div>
    </section>

    <!-- ===== Talks ===== -->
    <section id="talks" class="academic-container pb-8">
      <h2 class="section-heading">Invited Talks</h2>
      <ul class="list-disc list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300">
        {talks.map((t) => <li>{t}</li>)}
      </ul>
    </section>

    <!-- ===== Service & Awards ===== -->
    <section id="service" class="academic-container pb-8">
      <h2 class="section-heading">Service & Awards</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-2">Reviewing</h3>
          <ul class="list-disc list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300">
            {service.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-2">Awards</h3>
          <ul class="list-disc list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300">
            {awards.map((a) => <li>{a}</li>)}
          </ul>
        </div>
      </div>
    </section>
  </main>

  <!-- ===== Footer ===== -->
  <footer class="academic-container py-8 border-t border-gray-200 dark:border-gray-700 no-print">
    <p class="text-sm text-gray-400 dark:text-gray-500">
      &copy; <span id="year"></span> Chijun Sima
    </p>
  </footer>
</BaseLayout>
