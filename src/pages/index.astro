---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  awards,
  education,
  experience,
  lastUpdated,
  machineReadableResources,
  news,
  profile,
  publications,
  reviewing,
  talks,
  writeups,
} from '../data/profile';
---
<BaseLayout>
  <a href="#main" class="skip-link">Skip to main content</a>

  <div class="page-wrapper">
    <main id="main" tabindex="-1" itemscope itemtype="https://schema.org/Person">
      <meta itemprop="name" content="Chijun Sima" />
      <meta itemprop="url" content="https://www.chijunsima.com" />

      <!-- ── Header ── -->
      <header class="site-header">
        <div class="header-top">
          <nav class="header-nav no-print" aria-label="Page sections">
            <a href="#publications">Publications</a>
            <a href="#experience">Experience</a>
            <a href="#service">Service</a>
          </nav>
          <button id="theme-toggle" class="theme-toggle no-print" aria-label="Toggle dark mode" aria-pressed="false">☾</button>
        </div>

        <div class="header-card">
          <img
            src="/avatar.jpg"
            data-asset-src="/avatar.jpg"
            alt="Portrait of Chijun Sima"
            width="144"
            height="144"
            itemprop="image"
            class="avatar"
            loading="eager"
            decoding="async"
          />
          <div class="header-info">
            <h1 class="header-name">Chijun Sima</h1>
            <p class="header-title">
              Senior Software Development Engineer,
              <a href="https://www.tencent.com" itemprop="worksFor" itemscope itemtype="https://schema.org/Organization" target="_blank" rel="noopener noreferrer">
                <span itemprop="name">{profile.employer}'s {profile.department}</span>
              </a>
            </p>
            <p class="header-location">Guangzhou, China</p>

            <div class="header-links" role="list" aria-label="Contact and profiles">
              <a role="listitem" href="mailto:simachijun@gmail.com" itemprop="email">Email</a>
              <a role="listitem" href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" itemprop="sameAs" target="_blank" rel="noopener noreferrer">Google Scholar</a>

              <a role="listitem" href="https://www.linkedin.com/in/chijun-sima/" itemprop="sameAs" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
        </div>
      </header>

      <!-- ── News ── -->
      <section id="news" class="section" aria-labelledby="h-news">
        <h2 id="h-news" class="section-heading">News</h2>
        <ul class="news-list" role="list">
          {news.map((item, index) => (
            <li class="news-item" id={`news-${index + 1}`}>
              <time class="news-date" datetime={item.dateISO}>{item.dateLabel}</time>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── Selected Publications ── -->
      <section id="publications" class="section" aria-labelledby="h-pub">
        <h2 id="h-pub" class="section-heading">Selected Publications</h2>
        <p class="section-note">
          Full list on <a href="https://scholar.google.com/citations?user=8-HD_IEAAAAJ&hl=en" class="text-link" target="_blank" rel="noopener noreferrer">Google Scholar</a>.
        </p>
        <ol class="pub-list" reversed>
          {publications.map((pub) => (
            <li>
              <article class="pub-item" id={pub.id} itemscope itemtype="https://schema.org/ScholarlyArticle">
                <div class="pub-heading">
                  <span class="pub-venue">{pub.venue}</span>
                  {pub.link ? (
                    <a href={pub.link} class="pub-title text-link" itemprop="url" target="_blank" rel="noopener noreferrer">
                      <span itemprop="name">{pub.title}</span>
                    </a>
                  ) : (
                    <span class="pub-title" itemprop="name">{pub.title}</span>
                  )}
                </div>
                <p class="pub-authors" set:html={pub.authors.replace(/Chijun Sima/g, '<strong class="pub-self" itemprop="author">Chijun Sima</strong>')} />
                {pub.note && <p class="pub-note">{pub.note}</p>}
              </article>
            </li>
          ))}
        </ol>
      </section>

      <!-- ── Experience ── -->
      <section id="experience" class="section" aria-labelledby="h-exp">
        <h2 id="h-exp" class="section-heading">Research &amp; Industry Experience</h2>
        <div class="timeline">
          {experience.map((entry) => (
            <article class="timeline-entry" itemscope itemtype="https://schema.org/OrganizationRole">
              <div class="timeline-head">
                <div class="timeline-left">
                  <p class="timeline-org">
                    <a href={entry.orgUrl} target="_blank" rel="noopener noreferrer" itemprop="memberOf" itemscope itemtype="https://schema.org/Organization">
                      <strong itemprop="name">{entry.org}</strong>
                    </a>
                    {entry.location && <span class="muted"> · {entry.location}</span>}
                  </p>
                  <p class="timeline-role">
                    <span itemprop="roleName">{entry.role}</span>
                    {entry.subtitle && <span class="muted"> — {entry.subtitle}</span>}
                  </p>
                </div>
                <time class="timeline-period" datetime={entry.startDate}>{entry.period}</time>
              </div>

              {entry.projects.map((proj) => (
                <div class="project-block">
                  {proj.name && (
                    <p class="project-name">
                      {proj.name}
                      {proj.note && <span class="muted"> ({proj.note})</span>}
                    </p>
                  )}
                  <ul class="project-bullets">
                    {proj.bullets.map((b) => <li set:html={b} />)}
                  </ul>
                </div>
              ))}
            </article>
          ))}
        </div>
      </section>

      <!-- ── Education ── -->
      <section id="education" class="section" aria-labelledby="h-edu">
        <h2 id="h-edu" class="section-heading">Education</h2>
        <article class="edu-entry" itemprop="alumniOf" itemscope itemtype="https://schema.org/EducationalOrganization">
          <div class="timeline-head">
            <div class="timeline-left">
              <p class="timeline-org">
                <a href={education.schoolUrl} target="_blank" rel="noopener noreferrer">
                  <strong itemprop="name">{education.school}</strong>
                </a>
              </p>
              <p class="timeline-role">{education.degree}</p>
            </div>
            <time class="timeline-period" datetime={education.startDate}>{education.period}</time>
          </div>
          <p class="project-detail">{education.detail}</p>
        </article>
      </section>

      <!-- ── Talks ── -->
      <section id="talks" class="section" aria-labelledby="h-talks">
        <h2 id="h-talks" class="section-heading">Talks</h2>
        <div class="talks-card">
          <p class="prose-body" style="margin-bottom:0.25rem;">
            <em>Ekko: A Large-Scale Deep Learning Recommender System with Low-Latency Model Update.</em>
          </p>
          <p class="section-note" style="margin-bottom:0;">
            {talks.map((t, i) => (
              <Fragment>
                {i > 0 && '; '}
                {t.text} ({t.date})
              </Fragment>
            ))}
          </p>
        </div>
      </section>

      <!-- ── Service & Awards ── -->
      <section id="service" class="section" aria-labelledby="h-service">
        <h2 id="h-service" class="section-heading">Academic Service &amp; Selected Awards</h2>
        <div class="two-col">
          <div class="service-card">
            <h3 class="subsection-label">Reviewer</h3>
            <ul class="clean-list">
              {reviewing.map((s) => <li>{s}</li>)}
            </ul>
          </div>
          <div class="service-card">
            <h3 class="subsection-label">Awards</h3>
            <ul class="clean-list">
              {awards.map((a) => (
                <li>
                  {a.text}
                  {a.year && <span class="muted"> ({a.year})</span>}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- ── Write-ups ── -->
      <section id="writeups" class="section" aria-labelledby="h-writeups">
        <h2 id="h-writeups" class="section-heading">Selected Write-ups &amp; Links</h2>
        <div class="writeup-links">
          {writeups.map((ref) => (
            <a href={ref.href} target="_blank" rel="noopener noreferrer">{ref.label}</a>
          ))}
        </div>
      </section>
    </main>

    <footer class="site-footer no-print" role="contentinfo">
      <p>
        Last updated <time datetime={lastUpdated}>{lastUpdated}</time>.
      </p>
      <p>
        Machine-readable:
        {' '}
        {machineReadableResources.map((resource, index) => (
          <Fragment>
            {index > 0 && <span class="link-sep" aria-hidden="true">·</span>}
            <a href={resource.href}>{resource.label}</a>
          </Fragment>
        ))}
      </p>
      <p>&copy; <span id="year"></span> Chijun Sima</p>
    </footer>
  </div>
</BaseLayout>
